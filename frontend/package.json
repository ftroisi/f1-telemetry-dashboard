{
  "name": "f1-telemetry-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "tsc -b && vite build",
    "check:tsc": "tsc --noEmit",
    "check:audit": "pnpm dlx audit-ci@^7 --config ./audit-ci.jsonc",
    "check": "pnpm run check:tsc && pnpm run check:audit",
    "dev": "vite",
    "format": "pnpm exec prettier . --write",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "axios": "^1.18.1",
    "lucide-react": "^1.23.0",
    "protobufjs": "^8.6.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-toastify": "^11.1.0",
    "recharts": "^3.9.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "esbuild": "0.28.1",
    "postcss": "^8.5.16",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "^4.3.2",
    "terser": "5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
